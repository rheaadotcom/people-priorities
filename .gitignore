# ── Dependency directories ───────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# ── Build artifacts ──────────────────────────────────────────────────
dist/
build/
out/
.next/
public/build/

# ── Environment / secrets — NEVER commit these ───────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# Allow example templates to be committed
!.env.example
!.env.sample

# ── Logs ─────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# ── Database ─────────────────────────────────────────────────────────
*.sqlite3
*.db

# ── OS generated ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE / Editors ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo

# ── Testing / Coverage ───────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ─────────────────────────────────────────────────────────────
*.pem
.vercel
*.tsbuildinfo
